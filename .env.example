# Atrium environment configuration
# Copy to .env and fill in real values from Infisical

# Postgres password for the atrium-postgres container
ATRIUM_DB_PASSWORD=replace-me-with-strong-password

# Bearer token for the REST API (frontend uses this)
ATRIUM_API_TOKEN=replace-me-32-chars-min

# Bearer token for the MCP endpoint (Claude uses this via Provisioner)
ATRIUM_MCP_TOKEN=replace-me-32-chars-min

# Forge integration — leave default unless Forge URL changes
FORGE_URL=https://forge.millyweb.com

